generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id       Int        @id @default(autoincrement())
  name          String
  email         String     @unique
  password_hash String
  role          SystemRole @default(CANDIDATE)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  applications        Application[]   @relation("CandidateApplications")
  decidedApplications Application[]   @relation("ApplicationDecisionMaker")
  interviews          Interview[]     @relation("InterviewerInterviews")
  ownedProjects       Project[]       @relation("ProjectOwner")
  projectMembers      ProjectMember[]

  @@index([role])
  @@map("users")
}

model Project {
  project_id  Int      @id @default(autoincrement())
  name        String
  description String?
  owner_id    Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  owner User @relation("ProjectOwner", fields: [owner_id], references: [user_id], onDelete: Restrict)

  vacancies      Vacancy[]
  projectMembers ProjectMember[]

  @@index([owner_id])
  @@map("projects")
}

model Vacancy {
  vacancy_id  Int           @id @default(autoincrement())
  title       String
  description String?
  status      VacancyStatus @default(OPEN)
  project_id  Int
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt

  project Project @relation(fields: [project_id], references: [project_id], onDelete: Cascade)

  applications Application[]

  @@index([project_id])
  @@index([status])
  @@index([project_id, status])
  @@map("vacancies")
}

model Application {
  application_id   Int               @id @default(autoincrement())
  user_id          Int
  vacancy_id       Int
  status           ApplicationStatus @default(SUBMITTED)
  decision_by      Int?
  decision_comment String?
  decision_at      DateTime?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  user          User    @relation("CandidateApplications", fields: [user_id], references: [user_id], onDelete: Cascade)
  vacancy       Vacancy @relation(fields: [vacancy_id], references: [vacancy_id], onDelete: Cascade)
  decisionMaker User?   @relation("ApplicationDecisionMaker", fields: [decision_by], references: [user_id], onDelete: SetNull)

  interview Interview?

  @@unique([user_id, vacancy_id])
  @@index([user_id])
  @@index([vacancy_id])
  @@index([status])
  @@index([vacancy_id, status])
  @@map("applications")
}

model Interview {
  interview_id   Int             @id @default(autoincrement())
  application_id Int             @unique
  interviewer_id Int
  date           DateTime?
  status         InterviewStatus @default(ASSIGNED)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  application Application @relation(fields: [application_id], references: [application_id], onDelete: Cascade)
  interviewer User        @relation("InterviewerInterviews", fields: [interviewer_id], references: [user_id], onDelete: Restrict)

  result InterviewResult?

  @@index([interviewer_id])
  @@index([status])
  @@index([date])
  @@index([interviewer_id, status])
  @@map("interviews")
}

model InterviewResult {
  result_id      Int                     @id @default(autoincrement())
  interview_id   Int                     @unique
  score          Int
  comment        String?
  recommendation InterviewRecommendation
  created_at     DateTime                @default(now())
  updated_at     DateTime                @updatedAt

  interview Interview @relation(fields: [interview_id], references: [interview_id], onDelete: Cascade)

  // Prisma does not support CHECK constraints in schema.prisma.
  // Add in migration SQL: CHECK ("score" >= 0 AND "score" <= 10)
  @@map("interview_results")
}

model ProjectMember {
  id              Int      @id @default(autoincrement())
  project_id      Int
  user_id         Int
  role_in_project String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  project Project @relation(fields: [project_id], references: [project_id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([project_id, user_id, role_in_project])
  @@index([project_id])
  @@index([user_id])
  @@map("project_members")
}

enum SystemRole {
  CANDIDATE       @map("candidate")
  INTERVIEWER     @map("interviewer")
  PROJECT_MANAGER @map("project_manager")
}

enum VacancyStatus {
  OPEN   @map("open")
  CLOSED @map("closed")
  PAUSED @map("paused")
}

enum ApplicationStatus {
  SUBMITTED           @map("submitted")
  UNDER_REVIEW        @map("under_review")
  INTERVIEW_ASSIGNED  @map("interview_assigned")
  INTERVIEW_SCHEDULED @map("interview_scheduled")
  INTERVIEW_COMPLETED @map("interview_completed")
  ACCEPTED            @map("accepted")
  REJECTED            @map("rejected")
  WITHDRAWN           @map("withdrawn")
}

enum InterviewStatus {
  ASSIGNED  @map("assigned")
  SCHEDULED @map("scheduled")
  COMPLETED @map("completed")
  CANCELED  @map("canceled")
}

enum InterviewRecommendation {
  RECOMMENDED          @map("recommended")
  NOT_RECOMMENDED      @map("not_recommended")
  RESERVE              @map("reserve")
  ADDITIONAL_INTERVIEW @map("additional_interview")
}
